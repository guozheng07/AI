<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>商品建档 Agent — 技术架构设计文档</title>
  <style>
    :root {
      --brand:#FF6B35;--brand-light:#FFF3EE;
      --blue:#3B82F6;--blue-light:#EFF6FF;
      --green:#10B981;--green-light:#ECFDF5;
      --purple:#8B5CF6;--purple-light:#F5F3FF;
      --amber:#F59E0B;--amber-light:#FFFBEB;
      --red:#EF4444;--red-light:#FEF2F2;
      --g50:#F9FAFB;--g100:#F3F4F6;--g200:#E5E7EB;--g300:#D1D5DB;
      --g400:#9CA3AF;--g500:#6B7280;--g600:#4B5563;--g700:#374151;
      --g800:#1F2937;--g900:#111827;
      --r:12px;--sh:0 1px 3px rgba(0,0,0,.08),0 4px 12px rgba(0,0,0,.05);
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Hiragino Sans GB",sans-serif;background:var(--g50);color:var(--g800);line-height:1.6;font-size:14px}

    /* layout */
    .wrap{display:flex;min-height:100vh}
    .side{width:236px;flex-shrink:0;background:#fff;border-right:1px solid var(--g200);position:sticky;top:0;height:100vh;overflow-y:auto;padding:20px 0 40px}
    .side-logo{padding:0 18px 16px;border-bottom:1px solid var(--g100);margin-bottom:10px}
    .side-logo .badge{display:inline-flex;align-items:center;gap:5px;background:var(--brand-light);color:var(--brand);font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:7px}
    .side-logo h2{font-size:14px;font-weight:800;color:var(--g900);line-height:1.3}
    .nav-sec{padding:0 8px}
    .nav-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--g400);padding:10px 10px 3px}
    a.nav-a{display:flex;align-items:center;gap:7px;padding:6px 10px;border-radius:7px;font-size:12px;color:var(--g600);text-decoration:none;transition:background .12s,color .12s}
    a.nav-a:hover{background:var(--g100);color:var(--g900)}
    .nav-dot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}

    /* main */
    .main{flex:1;min-width:0}
    .hero{background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 60%,#0f3460 100%);color:#fff;padding:52px 60px 44px;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;top:-80px;right:-80px;width:320px;height:320px;background:radial-gradient(circle,rgba(255,107,53,.22) 0%,transparent 70%);pointer-events:none}
    .hero-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);padding:4px 12px;border-radius:20px;font-size:12px;margin-bottom:18px}
    .hero h1{font-size:34px;font-weight:800;line-height:1.2;margin-bottom:12px}
    .hero h1 span{color:var(--brand)}
    .hero p{font-size:15px;color:rgba(255,255,255,.65);max-width:620px;margin-bottom:28px;line-height:1.7}
    .hero-meta{display:flex;gap:20px;font-size:12px;color:rgba(255,255,255,.45)}

    .content{padding:36px 60px 80px;max-width:1080px}

    /* section */
    .sec{margin-bottom:48px}
    :target{scroll-margin-top:20px}
    .sec-hd{display:flex;align-items:center;gap:10px;margin-bottom:22px}
    .sec-num{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;flex-shrink:0}
    .sec-title{font-size:21px;font-weight:800;color:var(--g900)}
    .sec-title small{font-size:13px;font-weight:400;color:var(--g400);margin-left:8px}

    /* card */
    .card{background:#fff;border:1px solid var(--g200);border-radius:var(--r);padding:22px;box-shadow:var(--sh)}
    .card+.card{margin-top:14px}
    .card-title{font-size:13px;font-weight:700;color:var(--g700);margin-bottom:14px;display:flex;align-items:center;gap:7px}

    /* grids */
    .g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
    .g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}

    /* stack */
    .stack{background:#fff;border:1px solid var(--g200);border-radius:9px;padding:14px;box-shadow:var(--sh)}
    .stack-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--g400);margin-bottom:5px}
    .stack-val{font-size:13px;font-weight:700;color:var(--g800)}
    .pill{display:inline-block;font-size:10px;padding:2px 7px;border-radius:10px;margin-top:4px}

    /* layout diagram */
    .ld{background:var(--g900);border-radius:var(--r);padding:24px}
    .ld-row{display:flex;gap:6px;height:190px}
    .lp{border-radius:8px;display:flex;flex-direction:column;padding:14px;color:#fff;position:relative;overflow:hidden}
    .lp.task{width:22%;background:linear-gradient(160deg,#1e3a5f,#1a2f4e);border:1px solid rgba(59,130,246,.3)}
    .lp.chat{flex:1;background:linear-gradient(160deg,#1a2f1a,#162614);border:1px solid rgba(16,185,129,.3)}
    .lp.dlg{width:31%;background:linear-gradient(160deg,#2d1a3d,#24152f);border:1px solid rgba(139,92,246,.3)}
    .lp-name{font-size:13px;font-weight:700;margin-bottom:3px}
    .lp-sub{font-size:10px;opacity:.5;margin-bottom:10px}
    .lp-feat{font-size:10px;opacity:.65;line-height:1.9}
    .lp-range{position:absolute;bottom:10px;right:10px;font-size:9px;padding:2px 7px;border-radius:8px;background:rgba(255,255,255,.1);color:rgba(255,255,255,.5)}
    .dh{width:4px;background:rgba(255,255,255,.07);border-radius:2px;flex-shrink:0;align-self:stretch}

    /* features */
    .fg-title{font-size:13px;font-weight:700;color:var(--g700);margin-bottom:10px;display:flex;align-items:center;gap:7px}
    .fg-title::after{content:'';flex:1;height:1px;background:var(--g200)}
    .fl{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:9px;margin-bottom:22px}
    .fi{background:#fff;border:1px solid var(--g200);border-radius:9px;padding:13px;display:flex;align-items:flex-start;gap:9px;box-shadow:var(--sh)}
    .fi-ic{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
    .fi-name{font-size:12px;font-weight:700;color:var(--g800);margin-bottom:2px}
    .fi-desc{font-size:11px;color:var(--g500);line-height:1.5}

    /* SSE events */
    .sse-list{display:flex;flex-wrap:wrap;gap:7px}
    .sse{display:flex;align-items:center;gap:6px;background:var(--g50);border:1px solid var(--g200);border-radius:7px;padding:7px 11px}
    .sse code{font-family:"SF Mono",Menlo,monospace;font-size:10px;font-weight:700;color:var(--blue);background:var(--blue-light);padding:1px 5px;border-radius:3px}
    .sse span{font-size:11px;color:var(--g500)}

    /* block renderers */
    .blk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:9px}
    .blk{border-radius:8px;padding:11px 13px;border:1px solid}
    .blk-type{font-family:"SF Mono",Menlo,monospace;font-size:10px;font-weight:700;margin-bottom:3px}
    .blk-comp{font-size:12px;font-weight:600;margin-bottom:2px}
    .blk-desc{font-size:10px;opacity:.65}

    /* bridge */
    .bridge{display:flex;align-items:center;gap:0;overflow-x:auto;padding:8px 0}
    .bn{border-radius:9px;padding:11px 14px;text-align:center;flex-shrink:0;min-width:110px}
    .bn-t{font-size:12px;font-weight:700;margin-bottom:3px}
    .bn-s{font-size:10px;opacity:.55}
    .ba{flex:1;min-width:36px;text-align:center;color:var(--g300);font-size:20px;position:relative}
    .ba-lbl{position:absolute;top:-17px;left:50%;transform:translateX(-50%);font-size:9px;white-space:nowrap;background:var(--blue-light);color:var(--blue);padding:1px 5px;border-radius:5px;font-weight:600}

    /* defense */
    .def{display:flex;align-items:flex-start;gap:14px;padding:15px;border-radius:9px;border:1px solid var(--g200);background:#fff;box-shadow:var(--sh)}
    .def+.def{margin-top:9px}
    .def-num{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;flex-shrink:0}
    .def-title{font-size:13px;font-weight:700;color:var(--g800)}
    .def-desc{font-size:12px;color:var(--g500);margin-top:2px}
    .def-code{font-family:"SF Mono",Menlo,monospace;font-size:10px;background:var(--g100);color:var(--g700);padding:1px 6px;border-radius:3px;display:inline-block;margin-top:5px}

    /* flow */
    .flow{display:flex;flex-direction:column}
    .fstep{display:flex;align-items:stretch;gap:0}
    .fline{display:flex;flex-direction:column;align-items:center;width:36px;flex-shrink:0}
    .fdot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:5px}
    .fconn{flex:1;width:2px;background:var(--g200);margin:3px 0}
    .fcnt{flex:1;padding:3px 0 14px 6px}
    .ft{font-size:12px;font-weight:600;color:var(--g800)}
    .fd{font-size:11px;color:var(--g500);margin-top:1px}

    /* service table */
    .stbl{width:100%;border-collapse:collapse;font-size:12px}
    .stbl th{text-align:left;padding:9px 14px;background:var(--g50);color:var(--g500);font-size:11px;font-weight:600;border-bottom:1px solid var(--g200)}
    .stbl td{padding:11px 14px;border-bottom:1px solid var(--g100);vertical-align:top}
    .stbl tr:last-child td{border-bottom:none}
    .sn{font-family:"SF Mono",Menlo,monospace;font-size:11px;font-weight:600;padding:2px 6px;border-radius:4px}

    /* data flow dark */
    .dfdk{background:var(--g900);border-radius:var(--r);padding:22px 26px;color:#fff}
    .dfph{margin-bottom:18px}
    .dfph-t{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:rgba(255,255,255,.35);margin-bottom:8px;display:flex;align-items:center;gap:7px}
    .dfph-t::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.07)}
    .dfit-list{display:flex;flex-wrap:wrap;gap:6px}
    .dfit{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.09);border-radius:7px;padding:6px 10px;font-size:11px}
    .dfit code{font-family:"SF Mono",Menlo,monospace;font-size:10px;font-weight:600}
    .dfit span{font-size:10px;color:rgba(255,255,255,.4)}
    .df-arrow{color:rgba(255,255,255,.2);font-size:16px;align-self:center}

    /* docs */
    .doc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:11px}
    .doc{background:#fff;border:1px solid var(--g200);border-radius:9px;padding:14px;display:flex;gap:11px;box-shadow:var(--sh);transition:box-shadow .15s,transform .15s}
    .doc:hover{box-shadow:0 4px 6px rgba(0,0,0,.07),0 10px 30px rgba(0,0,0,.08);transform:translateY(-1px)}
    .doc-ic{width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0}
    .doc-name{font-family:"SF Mono",Menlo,monospace;font-size:12px;font-weight:700;color:var(--g800);margin-bottom:3px}
    .doc-desc{font-size:11px;color:var(--g500);line-height:1.5}

    @media(max-width:900px){
      .side{display:none}
      .hero{padding:32px 20px 24px}
      .content{padding:20px 20px 60px}
      .hero h1{font-size:24px}
      .g2,.g3,.g4{grid-template-columns:1fr}
      .ld-row{flex-direction:column;height:auto}
      .lp.task,.lp.dlg{width:100%;height:100px}
      .bridge{flex-direction:column;align-items:flex-start;gap:8px}
    }
  </style>
</head>
<body>
<div class="wrap">

<!-- ── Sidebar ── -->
<nav class="side">
  <div class="side-logo">
    <div class="badge">🤖 SKU-Agent</div>
    <h2>技术架构<br/>设计文档</h2>
  </div>
  <div class="nav-sec">
    <div class="nav-lbl">概览</div>
    <a href="#arch" class="nav-a"><span class="nav-dot"></span>整体架构</a>
    <a href="#layout" class="nav-a"><span class="nav-dot"></span>UI 布局</a>
  </div>
  <div class="nav-sec">
    <div class="nav-lbl">业务功能</div>
    <a href="#features" class="nav-a"><span class="nav-dot"></span>功能清单</a>
  </div>
  <div class="nav-sec">
    <div class="nav-lbl">核心技术</div>
    <a href="#sse" class="nav-a"><span class="nav-dot"></span>SSE 实时流</a>
    <a href="#bridge" class="nav-a"><span class="nav-dot"></span>UI Bridge</a>
    <a href="#isolation" class="nav-a"><span class="nav-dot"></span>会话隔离</a>
    <a href="#resume" class="nav-a"><span class="nav-dot"></span>断点续传</a>
    <a href="#table" class="nav-a"><span class="nav-dot"></span>表格双向链路</a>
    <a href="#state" class="nav-a"><span class="nav-dot"></span>状态管理</a>
    <a href="#queue" class="nav-a"><span class="nav-dot"></span>消息排队</a>
    <a href="#upload" class="nav-a"><span class="nav-dot"></span>文件上传</a>
  </div>
  <div class="nav-sec">
