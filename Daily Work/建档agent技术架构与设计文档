      <span style="color:#9ca3af">// 内层：observer 包裹，直接读取响应式属性（$ 结尾）</span><br/>
      <span style="color:#60a5fa">const</span> SkuAgentContent = <span style="color:#34d399">observer</span>(({ agentType, globalEventService }) => {<br/>
